    <div id="main">
      <!-- Carousel start -->
      <section class="carousel-section">
        <div id="carouselControls" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
          <div class="carousel-inner">
            <% @banners.each_with_index do |banner, index| %>
              <div class="carousel-item <%= 'active' if index == 0 %>">
                <% if banner.image.attached? %>
                  <%= image_tag banner.image, class: "d-block w-100 card-services" %>
                <% end %>
                <div class="container">
                  <div class="carousel-text">
                    <h1><%= banner.title %></h1>
                    <h3><%= banner.subtitle %></h3>
                    <div class="carousel-button mt-3">
                      <% if banner.button_link.present? %>
                        <%= link_to banner.button_text.presence, banner.button_link, class: "btn btn-secondary shadow-sm" %>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#carouselControls" data-bs-slide="prev">
            <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#carouselControls" data-bs-slide="next">
            <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </section>
      <!-- Carousel end -->
      <!-- About start -->
      <section class="about-section">
        <div class="container">
          <div class="row">
            <div class="col-12 col-lg-6">
              <div class="about-photo imagebox about-info">
                <img class="img-fluid rounded shadow" src="/static-assets/images/about.jpg" alt="About Us">
              </div>
            </div>
            <div class="col-12 col-lg-6">
              <div class="about-info">
                <h2>The Story Behind Anuvia</h2>
                <hr>
                <p>Anuvia started as a static website built from a Bootstrap template, created as a foundation to explore layout structure, responsive design, and front-end customization.</p>
                <p>As the project evolved, it was rebuilt into a fully dynamic Ruby on Rails application following the MVC architecture pattern. What began as a visual concept became a complete full-stack project.</p>
                <p>Today, Anuvia includes user authentication, an admin dashboard, CRUD operations, PostgreSQL database integration, and cloud storage for media management. The project represents not only a beauty spa concept, but also a practical demonstration of continuous learning and technical growth.</p>
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- About end -->
      <!-- Discounts start -->
      <section class="discounts-section shadow">
        <div class="container">
          <div class="row">
            <div class="col-12 col-lg-6">
              <div class="discounts-info">
                <h2>Interested in a Project Like This?</h2>
                <hr>
                <p>Anuvia started as a simple static template and evolved into a fully dynamic Ruby on Rails application. If you are looking for a modern, responsive, and scalable website for your business, this project demonstrates what can be built from concept to deployment.</p>
                <p>From design customization to backend functionality, authentication systems, admin dashboards, and database integration — your idea can become a complete web application.</p>
                <p>If you're interested in creating a website or web system tailored to your needs, feel free to get in touch.</p>
                <a class="btn btn-primary" href="/contact" role="button">Get In Touch</a>
              </div>
            </div>
            <div class="col-12 col-lg-6">
              <div class="imagebox discounts-info">
                <img class="img-fluid rounded shadow float-end" src="/static-assets/images/discounts.jpg" alt="Discounts">
              </div>
            </div>
          </div>
        </div>
      </section>
      <!-- Discounts end -->
      <!-- Team start -->
      <section class="team-section">
        <div class="container">
          <div class="team-section-title text-center mb-5">
            <h2 class="mb-4">Meet Us</h2>
            <p class="lead mb-4">We are a group of innovative, experienced, and proficient teams. You will love to collaborate with us.</p>
            <hr class="w-50 mx-auto mb-4">
          </div>
          <div class="row">
            <% @members.each do |member| %>
              <div class="col-12 col-md-6 col-lg-3 mb-4">
                <div class="card shadow border-0">
                  <% if member.image.attached? %>
                    <%= link_to member do %>
                      <%= image_tag member.image, class: "img-fluid rounded shadow card-team", width: 300 %>
                    <% end %>
                  <% end %>
                  <div class="card-body text-center">
                    <%= link_to member_path(member), class: "text-decoration-none" do%>
                      <h3 class="team-title"><%= member.name %></h3>
                    <% end %>
                    <h5 class="team-subtitle"><%= member.role %></h5>
                    <hr>
                    <div class="d-flex justify-content-center">
                      <a href="#" class="mx-2"><i class="fa-xl fa-brands fa-facebook"></i></a>
                      <a href="#" class="mx-2"><i class="fa-xl fa-brands fa-twitter"></i></a>
                      <a href="#" class="mx-2"><i class="fa-xl fa-brands fa-instagram"></i></a>
                      <a href="#" class="mx-2"><i class="fa-xl fa-brands fa-linkedin"></i></a>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="text-center mt-4">
            <%= link_to "Read More", members_path, class: "btn btn-outline-primary shadow" %>
          </div>
        </div>
      </section>
      <!-- Team end -->
      <!-- Services start -->
      <section class="services-section shadow">
        <div class="container">
          <div class="services-section-title text-center mb-5">
            <h2 class="mb-4">Our Services</h2>
            <p class="lead mb-4">Experience the excellence in beauty and relaxation at our salon, where every service is carefully crafted to enhance your unique beauty and rejuvenate your mind and body.</p>
            <hr class="w-50 mx-auto mb-4">
          </div>
          <div class="row">
            <% @services.each do |service| %>
              <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card shadow border-0">
                  <% if service.image.attached? %>
                    <%= link_to service_path(service) do %>
                      <%= image_tag service.image, class: "img-fluid rounded shadow card-services" %>
                    <% end %>
                  <% end %>
                  <div class="card-body text-center">
                    <%= link_to service do %>
                      <h4 class="services-title"><%= service.title %></h4>
                    <% end %>
                  </div>
                  <ul class="list-group list-group-flush">
                    <li class="list-group-item"><%= service.text_field1 %></li>
                    <li class="list-group-item"><%= service.text_field2 %></li>
                    <li class="list-group-item"><%= service.text_field3 %></li>
                  </ul>
                  <div class="card-body text-center">
                    <%= link_to "Read More", service, class: "btn btn-outline-primary shadow" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="text-center mt-4">
            <%= link_to "Read More", services_path, class: "btn btn-primary shadow" %>
          </div>
        </div>
      </section>
      <!-- Services end -->
      <!--Blog start -->
      <section class="blog-section">
        <div class="container">
          <div class="blog-section-title">
            <h2 class="mb-4">Our latest news</h2>
            <p class="mb-4 lead">Stay informed with our latest news. Discover whats making people talk on our blog </p>
            <hr class="w-50 mx-auto mb-4">
          </div>
          <div class="row">
            <% @posts.each do |post| %>
              <div class="card-blog col-12 col-md-6 col-lg-4">
                <div class="blog-content shadow">
                  <% if post.image.attached? %>
                    <%= link_to post do %>
                        <%= image_tag post.image, class: "card-img-top rounded" %>
                      <% end %>
                    <% end %>
                  <div class="card-body">
                    <%= link_to post do %>
                      <h4 class="blog-title"><%= post.title %></h4>
                    <% end %>
                    <p class="blog-subtitle lead"><%= post.headline %></p>
                    <div class="blog-list">
                      <ul class="d-flex justify-content-center align-items-center">
                        <li>
                          <i class="fa-regular fa-user"></i>
                          <%= post.user.name %>
                        </li>
                        <li style="color: #6c757d;">
                          <i class="fa-regular fa-clock"></i>
                          <%= post.created_at.strftime("%d/%m/%Y") %>
                        </li>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          <div class="btn-read-more">
            <%= link_to "Read More", posts_path, class: "btn btn-outline-primary shadow" %>
          </div>
        </div>
      </section>
      <!-- Blog end -->
    </div>
